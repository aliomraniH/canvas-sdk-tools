# canvas-sdk-tools — environment.  Copy to .env for local dev; the operator sets
# these as Replit Reserved VM secrets in production.

# Bearer token required on every /mcp request.  DISTINCT from the memory server's
# token.  Generate a long random value.
MCP_AUTH_TOKEN=replace-me

# Network binding.
HOST=0.0.0.0
PORT=8000

# Logging.
LOG_LEVEL=INFO

# Default SDK reference bucket when a tool call omits sdk_version.
DEFAULT_SDK_VERSION=0.169.x

# NOTE: there are intentionally NO Canvas credentials, NO database URL, and NO
# embedding-provider keys here.  This service is static, offline, and stateless.
